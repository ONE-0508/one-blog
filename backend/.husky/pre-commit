#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🚀 Running pre-commit checks..."

# 运行lint-staged
npx lint-staged

# 运行TypeScript类型检查
echo "🔍 Running TypeScript type check..."
npm run type-check

# 如果type-check失败，退出
if [ $? -ne 0 ]; then
  echo "❌ TypeScript type check failed. Please fix the errors before committing."
  exit 1
fi

echo "✅ All pre-commit checks passed!"